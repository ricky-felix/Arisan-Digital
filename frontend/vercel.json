{
	"rewrites": [{ "source": "/(.*)", "destination": "/" }],
	"build": {
		"env": {
			"NODE_ENV": "production"
		}
	},
	"headers": [
		{
			"source": "/(.*)",
			"headers": [
				{
					"key": "X-Content-Type-Options",
					"value": "nosniff"
				}
			]
		}
	],
	"experimentalServices": {
        "frontend": {
            "root": "frontend",
            "routePrefix": "/",
            "framework": "vite",
			"outputDirectory": "./frontend/dist"
        },
        "backend": {
            "root": "backend",
            "routePrefix": "/",
			"outputDirectory": "./backend/dist"
        }
}
}
