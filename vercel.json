{
	"rewrites": [{ "source": "/(.*)", "destination": "/" }],
	"build": {
		"env": {
			"NODE_ENV": "production"
		}
	},
	"headers": [
		{
			"source": "/(.*)",
			"headers": [
				{
					"key": "X-Content-Type-Options",
					"value": "nosniff"
				}
			]
		}
	],
	"experimentalServices": {
		"frontend": {
			"root": "frontend",
			"routePrefix": "./frontend",
			"framework": "vite"
		},
		"backend": {
			"root": "backend",
			"routePrefix": "./backend",
			"framework": "nestjs"
		}
	}
}
