# Supabase — get from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
# Use the service_role key (never expose this in the frontend)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Server
PORT=3000

# CORS — set to your frontend dev origin
FRONTEND_URL=http://localhost:5173

# Payment gateway webhook secrets
# Xendit: Dashboard → Settings → Webhook → Callback Token
XENDIT_WEBHOOK_TOKEN=your-xendit-callback-token-here
# Midtrans: Dashboard → Settings → Access Keys → Server Key
MIDTRANS_SERVER_KEY=your-midtrans-server-key-here
